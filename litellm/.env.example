# AQUEST FITXER ÉS NOMÉS DE REFERÈNCIA. NO S'USA.
#
# Font de veritat: ~/.platform/.env
#
# Per configurar la plataforma:
#   cp ~/.platform/.env  (ja hauria d'existir)
#   o executa: platform config
#
# Aquest fitxer existeix com a documentació de les variables disponibles.
# Docker Compose llegeix directament ~/.platform/.env.

ANTHROPIC_API_KEY=          # Opcional. Només cal si vols Claude via LiteLLM.
                             # Claude Code amb login de compte NO requereix aquesta clau.
DEEPSEEK_API_KEY=           # Obligatòria per DeepSeek V4 Pro/Flash.
LITELLM_MASTER_KEY=sk-local-platform
LITELLM_HOST=127.0.0.1
LITELLM_PORT=4000
PROJECTS_DIR=$HOME/Projects
PLATFORM_DIR=$HOME/platform
